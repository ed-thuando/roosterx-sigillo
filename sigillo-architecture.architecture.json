    { "from": "browser", "to": "google", "variant": "security", "fromSide": "right", "toSide": "left" },
    { "from": "google", "to": "appworker", "label": "ID token", "variant": "security", "fromSide": "right", "toSide": "top" },
    { "from": "browser", "to": "appworker", "label": "HTTPS · REST / RSC", "variant": "emphasis", "fromSide": "right", "toSide": "left" },
    { "from": "cli", "to": "appworker", "label": "Device Grant (RFC 8628)", "variant": "emphasis", "fromSide": "right", "toSide": "left" },
    { "from": "ci", "to": "appworker", "label": "Bearer token", "variant": "security", "fromSide": "right", "toSide": "left" },
    { "from": "cli", "to": "child", "label": "inject · redact", "variant": "emphasis", "fromSide": "bottom", "toSide": "top", "labelDy": 30 },
    { "from": "appworker", "to": "authz", "fromSide": "bottom", "toSide": "top" },
    { "from": "appworker", "to": "d1model", "fromSide": "top", "toSide": "left" },
    { "from": "appworker", "to": "secretlog", "label": "set / delete", "fromSide": "right", "toSide": "left" },
    { "from": "keystore", "to": "secretlog", "label": "encrypt", "variant": "dashed", "fromSide": "bottom", "toSide": "top" },
