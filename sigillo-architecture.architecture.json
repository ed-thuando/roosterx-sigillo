  "cards": [
    { "dot": "rose", "title": "Authentication", "items": ["Browser: Google/Firebase hosted OIDC → sig_session cookie", "CLI: Device Authorization Grant (RFC 8628)", "CI / agents: API-token bearer"] },
    { "dot": "amber", "title": "Authorization & isolation", "items": ["CASL roles: org-admin, project-admin, member, viewer", "Organization / project / environment scoping", "Tab & action visibility gated by ability"] },
    { "dot": "emerald", "title": "Secret lifecycle", "items": ["Event-sourced secret_event (set / delete)", "AES-256-GCM encrypt at rest; key never in D1", "Decrypt only in Worker; injected into child env", "Output redacted; no plaintext on disk unless --mount"] },
    { "dot": "cyan", "title": "Runtime targets & formats", "items": ["run injects env into any process", "mount / download: env, json, yaml, docker, dotnet-json", "Consumed by CI (GitHub Actions), containers, .NET"] }
