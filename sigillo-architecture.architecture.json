    { "id": "cli", "type": "frontend", "label": "Sigillo CLI", "sublabel": "login·setup·run·secrets", "row": 1, "col": 1 },
    { "id": "child", "type": "backend", "label": "Child Process", "sublabel": "app under `run`", "row": 2, "col": 1 },
    { "id": "ci", "type": "external", "label": "CI / AI Agents", "sublabel": "GitHub Actions", "row": 2, "col": 0, "tag": "SIGILLO_TOKEN" },
    { "id": "google", "type": "external", "label": "Google / Firebase", "sublabel": "hosted login", "row": 0, "col": 2, "tag": "OIDC ID token" },
