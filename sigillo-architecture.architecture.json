    { "id": "apitoken", "type": "security", "label": "API Tokens", "sublabel": "project + env scoped", "row": 2, "col": 5, "tag": "bearer" },
    { "id": "session", "type": "database", "label": "Session", "sublabel": "sig_session cookie", "row": 3, "col": 5 }
